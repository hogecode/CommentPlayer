# Caddyfile - HTTPS リバースプロキシ設定
# CommePlayer 開発環境用

my.local.comment.player {
	# フロントエンド (Vite React Dev Server)
	handle /api* {
		reverse_proxy localhost:8000
	}

	# デフォルトはVite Dev Serverへ
	reverse_proxy localhost:3000

	# 自己署名証明書を使用
	tls internal
}

# localhost でのアクセスも許可
localhost:7001 {
	reverse_proxy /api localhost:8000
	reverse_proxy localhost:3000
	tls internal
}
