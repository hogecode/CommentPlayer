# CommentVideo サーバー設定

# サーバー設定
server:
  host: "0.0.0.0"
  port: 8000
  jwt_secret: "your_jwt_secret_key_here"

# データベース設定
db:
  dsn: "app.db"
  max_open_conns: 10
  max_idle_conns: 5
  log_level: "silent"

# ログ設定
log:
  level: "info"
  format: "json"

# ストレージ設定
storage:
  captures_dir: "C:\\Users\\user\\Pictures\\Screenshots"
